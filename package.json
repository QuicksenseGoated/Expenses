{
  "name": "cadence",
  "productName": "Cadence",
  "version": "1.0.0",
  "description": "A results-driven content planner — strategy, briefs, calendar, pipeline, and performance tracking.",
  "main": "main.js",
  "author": "Quicksense",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "start": "electron .",
    "serve": "npx --yes serve src -l 5173",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win",
    "dist:linux": "electron-builder --linux"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.quicksense.cadence",
    "productName": "Cadence",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "assets/**/*"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "assets/icon.icns"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png"
    }
  }
}
